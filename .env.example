EXPERIMENTAL_ARM=BASELINE
LLM_PROVIDER=anthropic
LLM_MODEL=claude-3-5-sonnet-20240620
ANTHROPIC_API_KEY=

TEST_BANK_PATH=test_bank.csv
RESULTS_DIR=results
TEMPERATURE=0
MAX_TOKENS=1000

MCP_SERVER_URL=http://localhost:3001/mcp
MCP_AUTH_HEADER=Bearer admin-secret-key
MAX_TOOL_ROUNDS=8

# Baseline mode is offline SQL generation only. It does not connect to a database.
BASELINE_SQL_DIALECT=duckdb

# Optional. If set, this schema file is used for baseline mode.
BASELINE_SCHEMA_PATH=

# Optional inline schema or reference SQL for baseline mode.
RAW_DDL_SCHEMA=
