# Toggle this back and forth to run your separate tests: BASELINE or MCP
EXPERIMENTAL_ARM=BASELINE

# LLM Selection
LLM_PROVIDER=gemini # Options: anthropic, openai, gemini
# LLM_MODEL=claude-sonnet-4-5
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
GEMINI_API_KEY=
LLM_MODEL=gemini-2.5-flash



DB_CONNECTION_STRING=postgresql://user:pass@localhost:5432/warehouse

TEST_BANK_PATH=test_bank.csv
RESULTS_DIR=results
TEMPERATURE=0
MAX_TOKENS=1000
MAX_TOOL_ROUNDS=8

# Your local web server endpoint and security access token
MCP_SERVER_URL=http://localhost:3001/mcp
MCP_AUTH_HEADER="Bearer admin-secret-key"


# Baseline mode is offline SQL generation only. It does not connect to a database.
BASELINE_SQL_DIALECT=duckdb

# Optional. If not set, the built-in demo schema is used for baseline mode.
BASELINE_SCHEMA_PATH=./schema.sql

# Optional inline schema for baseline mode. Prefer BASELINE_SCHEMA_PATH for larger schemas.
RAW_DDL_SCHEMA=

SEMANTIC_DEFAULT=on # on | off
SEMANTIC_DIR=./semantic